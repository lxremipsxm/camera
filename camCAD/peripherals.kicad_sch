		(exclude_from_sim no)
		(at 141.732 333.248 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0a9d63e8-07f9-4298-b346-b07dc9525720")
	)
	(text "\nActual Product: 1987-DT024ETFT-IPS-SHB-ND\n\n3-Line 9-bit Serial Comms\n\nIM[1:0] = 01; IM1(PA9) = LOW, IM0(PA8) = HIGH\n\nUsing SPI3, RESET bound to PA2 GPIO"
		(exclude_from_sim no)
		(at 328.93 80.772 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
		)
		(uuid "208b8e27-3a85-4514-a88c-98307aa60b00")
	)
	(text "CD - GPIO PB0"
		(exclude_from_sim no)
		(at 320.04 171.45 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "57f4b735-cb08-4403-aa94-b153e2ddad01")
	)
	(text "SWCLK"
		(exclude_from_sim no)
		(at 292.1 224.79 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "6a2d2756-e396-4111-a560-2c47136faaf1")
	)
	(text "**DCMI Alternate Function mappings**\n\nPA4 - HSYNC \nPB7 - VSYNC \nPA6 - PCLK \nPA9, PC6 - D0 \nPA10, PC7 - D1\nPC8, PE0 - D2\nPC9, PE1 - D3\nPC11, PE4 - D4\nPB6 - D5 \nPB8, PE5 - D6\nPB9, PE6 - D7\nPC10 - D8 \nPC12 - D9\nPB5 - D10\nPD2 - D11\nPF11 - D12\nPG15 - D13\n\n\n**Available SPI AF Mappings**\n\n_SPI1_ (PA6 in use by OV)\nPA4, PA15 - NSS\nPA5, PB3 - SCK\nPB4 - MISO\nPA7, PB5 - MOSI\n\n_SPI2_ (MicroSD)\nPB12, PB9 - NSS\nPC3, PB15 - MOSI\nPB10, PB13 - SCK\nPB14, PC2 - MISO\n\n\n_SPI3_ (ILI9341)\nPA3, A15 - NSS\nPC10, PB3 - SCK\nPC11, PB4 - MISO\nPC12, PB5 - MOSI\n\n\n**I2C Mappings**\n\n_I2C 1_\nPB5 - SMBA\nPB6, PB8 - SCL\nPB7, PB9 - SDA\n\n\n_I2C 2_ (OV7670)\nPF0, PB11 - SDA\nPF1, PB10 - SCL\nPF2, PB12 - SMBA\n\n_I2C 3_ \nPC9 - SDA\nPA8 - SCL\nPA9 - SMBA\n\n\n\n\n\n"
		(exclude_from_sim no)
		(at 441.96 125.476 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "7ec1f75a-8554-45ae-988b-5a5895f26645")
	)
	(text "SWDIO"
		(exclude_from_sim no)
		(at 291.846 222.25 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ea3a4aec-e1fc-4c69-8b53-cabfcc016306")
	)
